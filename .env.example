# --- Data Provider ---
# Options: yfinance (free), cboe (free, accurate OI), ib (requires TWS/Gateway)
API_PROVIDER=cboe

# --- CBOE (free delayed options data) ---
CBOE_DELAY=0.5

# --- Interactive Brokers (only used when API_PROVIDER=ib) ---
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1
IB_MAX_EXPIRATIONS=4
IB_MIN_STRIKE_PCT=0.70
IB_MAX_STRIKE_PCT=1.30

# --- Scanner defaults ---
MAX_CONCURRENT_TICKERS=5
